{
  "cli": {
    "version": ">= 5.9.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://match-quota-analyzer.preview.emergentagent.com"
      },
      "distribution": "internal"
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://match-quota-analyzer.preview.emergentagent.com"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
